<!-- LAB 1 -->
<div class="activity">
<div class="badge">LAB 1</div>
<h2>Basic Form Creation</h2>

<pre>
&lt;form method="get"&gt;
 Name: &lt;input type="text" name="name"&gt;
 &lt;input type="submit"&gt;
&lt;/form&gt;

&lt;?php
if(isset($_GET['name'])){
 echo "Hello, " . $_GET['name'];
}
?&gt;
</pre>

<div class="answer">
Displays the entered name using the <span class="green">GET</span> method.
</div>
</div>

<!-- LAB 2 -->
<div class="activity">
<div class="badge">LAB 2</div>
<h2>Using POST Method</h2>

<pre>
&lt;form method="post"&gt;
 Name: &lt;input type="text" name="name"&gt;
 &lt;input type="submit"&gt;
&lt;/form&gt;

&lt;?php
if(isset($_POST['name'])){
 echo $_POST['name'];
}
?&gt;
</pre>

<div class="answer">
POST hides data from the URL and is safer than GET.
</div>
</div>

<!-- LAB 3 -->
<div class="activity">
<div class="badge">LAB 3</div>
<h2>Multiple Inputs</h2>

<pre>
&lt;form method="post"&gt;
 Name: &lt;input type="text" name="name"&gt;&lt;br&gt;
 Email: &lt;input type="text" name="email"&gt;&lt;br&gt;
 &lt;input type="submit"&gt;
&lt;/form&gt;
</pre>

<div class="answer">
Displays Name and Email after submission.
</div>
</div>

<!-- LAB 4 -->
<div class="activity">
<div class="badge">LAB 4</div>
<h2>Form Validation</h2>

<pre>
if(empty($_POST["name"])) {
 echo "Name is required";
}
</pre>

<div class="answer">
Checks if required fields are empty.
</div>
</div>

<!-- LAB 5 -->
<div class="activity">
<div class="badge">LAB 5</div>
<h2>Prevent XSS</h2>

<pre>
echo htmlspecialchars($_POST['name']);
</pre>

<div class="answer">
<span class="green">htmlspecialchars()</span> prevents XSS attacks.
</div>
</div>

<!-- LAB 6 -->
<div class="activity">
<div class="badge">LAB 6</div>
<h2>Email Validation</h2>

<pre>
if(!filter_var($_POST['email'], FILTER_VALIDATE_EMAIL)){
 echo "Invalid email";
}
</pre>

<div class="answer">
Checks whether the email format is valid.
</div>
</div>

